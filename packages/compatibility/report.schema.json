{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawsembly.dev/schemas/compatibility-report.v1.json",
  "title": "Clawsembly compatibility report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "status", "target", "artifact", "evidence", "checks"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "status": { "enum": ["probing", "supported", "partial", "unsupported"] },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime", "browserBaseline"],
      "properties": {
        "runtime": { "const": "webcontainer" },
        "browserBaseline": { "type": "string", "minLength": 1 }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "version", "integrity", "nodeEngine", "tarballBytes", "unpackedBytes", "directDependencyCount", "nativeRiskDependencies", "shrinkwrapRootConsistency"],
      "properties": {
        "package": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "integrity": { "type": "string", "minLength": 1 },
        "nodeEngine": { "type": "string", "minLength": 1 },
        "tarballBytes": { "type": "integer", "minimum": 0 },
        "unpackedBytes": { "type": "integer", "minimum": 0 },
        "directDependencyCount": { "type": "integer", "minimum": 0 },
        "shrinkwrapRootConsistency": {
          "type": "object",
          "additionalProperties": false,
          "required": ["lockfileVersion", "compatible", "missingCount", "mismatchedCount", "missingDevDependencyCount"],
          "properties": {
            "lockfileVersion": { "type": "integer", "minimum": 0 },
            "compatible": { "type": "boolean" },
            "missingCount": { "type": "integer", "minimum": 0 },
            "mismatchedCount": { "type": "integer", "minimum": 0 },
            "missingDevDependencyCount": { "type": "integer", "minimum": 0 }
          }
        },
        "nativeRiskDependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "version", "reason"],
            "properties": {
              "name": { "type": "string" },
              "version": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "capturedAt", "path", "summary"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "enum": ["browser-runtime", "browser-security", "browser-performance", "gateway", "chat"] },
          "capturedAt": { "type": "string", "format": "date-time" },
          "path": { "type": "string" },
          "summary": { "type": "string" }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "status", "detail"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "label": { "type": "string", "minLength": 1 },
          "status": { "enum": ["pass", "warn", "fail", "pending"] },
          "detail": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
