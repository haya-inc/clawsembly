{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawsembly.dev/schemas/compatibility-report.v1.json",
  "title": "Clawsembly compatibility report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "status", "target", "artifact", "evidence", "checks"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "reportLatencySeconds": {
      "type": "integer",
      "description": "Optional whole seconds between artifact.upstreamPublishedAt and generatedAt; present only when the upstream npm publish time was available."
    },
    "status": { "enum": ["probing", "supported", "partial", "unsupported"] },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime", "runtimeVersion", "browserBaseline"],
      "properties": {
        "runtime": { "const": "browserpod" },
        "runtimeVersion": { "type": "string", "minLength": 1 },
        "browserBaseline": { "type": "string", "minLength": 1 }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "version", "integrity", "nodeEngine", "tarballBytes", "unpackedBytes", "directDependencyCount", "directDependencies", "gatewayContract", "nativeRiskDependencies", "shrinkwrapRootConsistency"],
      "properties": {
        "package": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "integrity": { "type": "string", "minLength": 1 },
        "upstreamPublishedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Optional npm registry publish timestamp for this exact version, from the packument time field."
        },
        "nodeEngine": { "type": "string", "minLength": 1 },
        "tarballBytes": { "type": "integer", "minimum": 0 },
        "unpackedBytes": { "type": "integer", "minimum": 0 },
        "directDependencyCount": { "type": "integer", "minimum": 0 },
        "directDependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "spec", "resolvedVersion", "integrity"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "spec": { "type": "string", "minLength": 1 },
              "resolvedVersion": {
                "oneOf": [
                  { "type": "string", "minLength": 1 },
                  { "type": "null" }
                ]
              },
              "integrity": {
                "oneOf": [
                  { "type": "string", "minLength": 1 },
                  { "type": "null" }
                ]
              }
            }
          }
        },
        "gatewayContract": {
          "type": "object",
          "additionalProperties": false,
          "required": ["inspection", "protocol", "distribution", "inventories", "sources"],
          "properties": {
            "inspection": {
              "type": "object",
              "additionalProperties": false,
              "required": ["status", "limitations"],
              "properties": {
                "status": { "enum": ["complete", "incomplete"] },
                "limitations": { "$ref": "#/$defs/stringList" }
              }
            },
            "protocol": {
              "type": "object",
              "additionalProperties": false,
              "required": ["current", "minClient", "minProbe", "minNode"],
              "properties": {
                "current": { "$ref": "#/$defs/nullableNonnegativeInteger" },
                "minClient": { "$ref": "#/$defs/nullableNonnegativeInteger" },
                "minProbe": { "$ref": "#/$defs/nullableNonnegativeInteger" },
                "minNode": { "$ref": "#/$defs/nullableNonnegativeInteger" }
              }
            },
            "distribution": {
              "type": "object",
              "additionalProperties": false,
              "required": ["legacyPluginDeclarationCount"],
              "properties": {
                "legacyPluginDeclarationCount": { "type": "integer", "minimum": 0 }
              }
            },
            "inventories": {
              "type": "object",
              "additionalProperties": false,
              "required": ["coreMethods", "schemaExports", "validators", "eventSchemas"],
              "properties": {
                "coreMethods": { "$ref": "#/$defs/stringList" },
                "schemaExports": { "$ref": "#/$defs/stringList" },
                "validators": { "$ref": "#/$defs/stringList" },
                "eventSchemas": { "$ref": "#/$defs/stringList" }
              }
            },
            "sources": {
              "type": "object",
              "additionalProperties": false,
              "required": ["publicDeclaration", "publicRuntime", "versionModule", "serverMethods"],
              "properties": {
                "publicDeclaration": { "$ref": "#/$defs/nullableSourceRecord" },
                "publicRuntime": { "$ref": "#/$defs/nullableSourceRecord" },
                "versionModule": { "$ref": "#/$defs/nullableSourceRecord" },
                "serverMethods": { "$ref": "#/$defs/nullableSourceRecord" }
              }
            }
          }
        },
        "shrinkwrapRootConsistency": {
          "type": "object",
          "additionalProperties": false,
          "required": ["lockfileVersion", "compatible", "missingCount", "mismatchedCount", "missingDevDependencyCount"],
          "properties": {
            "lockfileVersion": { "type": "integer", "minimum": 0 },
            "compatible": { "type": "boolean" },
            "missingCount": { "type": "integer", "minimum": 0 },
            "mismatchedCount": { "type": "integer", "minimum": 0 },
            "missingDevDependencyCount": { "type": "integer", "minimum": 0 }
          }
        },
        "nativeRiskDependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "version", "reason"],
            "properties": {
              "name": { "type": "string" },
              "version": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "capturedAt", "path", "sha256", "summary"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "enum": ["browser-runtime", "browser-security", "browser-performance", "gateway", "chat"] },
          "capturedAt": { "type": "string", "format": "date-time" },
          "path": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "summary": { "type": "string" }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "status", "detail"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "label": { "type": "string", "minLength": 1 },
          "status": { "enum": ["pass", "warn", "fail", "pending"] },
          "detail": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "nullableNonnegativeInteger": {
      "oneOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "null" }
      ]
    },
    "nullableSourceRecord": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^sha256-[a-f0-9]{64}$" }
          }
        },
        { "type": "null" }
      ]
    }
  }
}
