{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawsembly.dev/schemas/release-history.v1.json",
  "title": "Clawsembly release history",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "package", "channels", "releases"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "package": { "type": "string", "minLength": 1 },
    "channels": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stable", "previous", "preview"],
      "properties": {
        "stable": { "type": "string", "minLength": 1 },
        "previous": { "type": "string", "minLength": 1 },
        "preview": { "type": "string", "minLength": 1 }
      }
    },
    "releases": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["channel", "version", "status", "reportPath", "generatedAt", "runtimeEvidence", "artifact", "checks", "deltaFromStable"],
        "properties": {
          "channel": { "enum": ["stable", "previous", "preview"] },
          "version": { "type": "string", "minLength": 1 },
          "status": { "enum": ["probing", "supported", "partial", "unsupported"] },
          "reportPath": { "type": "string", "minLength": 1 },
          "generatedAt": { "type": "string", "format": "date-time" },
          "runtimeEvidence": { "type": "boolean" },
          "artifact": {
            "type": "object",
            "additionalProperties": false,
            "required": ["integrity", "unpackedBytes", "directDependencyCount", "nativeRiskCount", "shrinkwrapConsistent", "shrinkwrapMissingCount", "shrinkwrapMismatchedCount"],
            "properties": {
              "integrity": { "type": "string", "minLength": 1 },
              "unpackedBytes": { "type": "integer", "minimum": 0 },
              "directDependencyCount": { "type": "integer", "minimum": 0 },
              "nativeRiskCount": { "type": "integer", "minimum": 0 },
              "shrinkwrapConsistent": { "type": "boolean" },
              "shrinkwrapMissingCount": { "type": "integer", "minimum": 0 },
              "shrinkwrapMismatchedCount": { "type": "integer", "minimum": 0 }
            }
          },
          "checks": { "$ref": "#/$defs/statusCounts" },
          "deltaFromStable": {
            "type": "object",
            "additionalProperties": false,
            "required": ["unpackedBytes", "directDependencyCount", "nativeRiskCount", "shrinkwrapMissingCount"],
            "properties": {
              "unpackedBytes": { "type": "integer" },
              "directDependencyCount": { "type": "integer" },
              "nativeRiskCount": { "type": "integer" },
              "shrinkwrapMissingCount": { "type": "integer" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "statusCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pass", "warn", "fail", "pending"],
      "properties": {
        "pass": { "type": "integer", "minimum": 0 },
        "warn": { "type": "integer", "minimum": 0 },
        "fail": { "type": "integer", "minimum": 0 },
        "pending": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
