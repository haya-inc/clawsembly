{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://haya-inc.github.io/clawsembly/schemas/capability-manifest.schema.json",
  "title": "Clawsembly capability permission manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "subject", "permissions"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "subject": { "$ref": "#/$defs/subject" },
    "permissions": {
      "type": "array",
      "maxItems": 10000,
      "items": { "$ref": "#/$defs/permission" }
    }
  },
  "$defs": {
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact", "runtime", "sessionId"],
      "properties": {
        "artifact": {
          "type": "object",
          "additionalProperties": false,
          "required": ["package", "version", "integrity"],
          "properties": {
            "package": { "const": "openclaw" },
            "version": { "type": "string", "minLength": 1 },
            "integrity": { "type": "string", "pattern": "^sha512-" }
          }
        },
        "runtime": { "const": "browserpod" },
        "sessionId": { "type": "string", "pattern": "^[A-Za-z0-9_-]{1,128}$" }
      }
    },
    "permission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capability", "scope", "requestedMaxCalls", "status", "expiresAt", "grantedMaxCalls"],
      "properties": {
        "capability": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$", "maxLength": 128 },
        "scope": { "type": "string", "minLength": 1, "maxLength": 256 },
        "requestedMaxCalls": { "type": "integer", "minimum": 1, "maximum": 10000 },
        "status": { "enum": ["pending", "granted", "denied", "revoked", "expired"] },
        "expiresAt": { "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }] },
        "grantedMaxCalls": { "oneOf": [{ "type": "integer", "minimum": 1, "maximum": 10000 }, { "type": "null" }] }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "enum": ["granted", "expired"] } }, "required": ["status"] },
          "then": {
            "properties": {
              "expiresAt": { "type": "string", "format": "date-time" },
              "grantedMaxCalls": { "type": "integer", "minimum": 1, "maximum": 10000 }
            }
          },
          "else": {
            "properties": {
              "expiresAt": { "type": "null" },
              "grantedMaxCalls": { "type": "null" }
            }
          }
        }
      ]
    }
  }
}
