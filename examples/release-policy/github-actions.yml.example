name: OpenClaw promotion observation

on:
  workflow_dispatch:
  schedule:
    - cron: "23 */6 * * *"

permissions:
  contents: read

jobs:
  clawsembly-policy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0 # v7
      - uses: actions/setup-node@48b55a011bda9f5d6aeb4c2d9c7362e8dae4041e # v6
        with:
          node-version: 24
      - name: Observe the Clawsembly promotion decision
        run: node examples/release-policy/check.mjs --observe
        # Remove --observe when HOLD should block this workflow.
